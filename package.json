{
  "name": "ServiceDeliver",
  "version": "0.1.0",
  "private": true,
  "description": "ServiceDeliver 根级 package（承载跨子项目共享的 E2E 测试依赖与 init-db.js 所需 mysql2）",
  "scripts": {
    "test:e2e": "playwright test --config vibe-web/playwright.config.ts",
    "test:e2e:headed": "playwright test --config vibe-web/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config vibe-web/playwright.config.ts --ui",
    "init-db": "node scripts/init-db.js"
  },
  "dependencies": {
    "mysql2": "^3.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0"
  }
}
