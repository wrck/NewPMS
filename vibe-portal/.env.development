# 开发环境
VITE_APP_TITLE=实施交付外部入口
# 接口代理目标（独立 npm run dev 时的默认值）
# 注意：start.ps1 启动时会根据 .env.ports 的 VIBE_SERVER_PORT 自动注入环境变量覆盖此值
# 如需指向远程后端，可显式设置环境变量：set VITE_API_TARGET=https://api.example.com
VITE_API_TARGET=http://localhost:8080
# 接口基础路径
VITE_API_BASE_URL=/api
# 客户端类型标识（外部入口 H5）
VITE_CLIENT_TYPE=PORTAL
# 客户 Token 有效期（毫秒，2h），用于本地过期前置判断
VITE_CUSTOMER_TOKEN_TTL=7200000
# Vite dev server 端口（与项目根目录 .env.ports 的 VIBE_PORTAL_PORT 保持一致）
VITE_PORT=5175
