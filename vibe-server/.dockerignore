# ============================================================================
# vibe-server .dockerignore
# 减少构建上下文体积，加速镜像构建
# ============================================================================

# Maven 构建产物
**/target/
**/*.jar
**/*.jar.original
**/*.war

# IDE 配置
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# 日志文件
*.log
logs/
**/logs/

# Git
.git/
.gitignore
.gitattributes

# 文档
*.md
docs/

# Docker 自身文件
Dockerfile
.dockerignore
docker-compose*.yml

# 临时文件
*.tmp
*.bak
*.swp
*~

# 操作系统文件
.DS_Store
Thumbs.db
