<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vibe.agent.mapper.OutsourceDeliverableMapper">

    <resultMap id="deliverableVoMap" type="com.vibe.agent.vo.OutsourceDeliverableVO">
        <id property="id" column="id"/>
        <result property="outsourceTaskId" column="outsource_task_id"/>
        <result property="deliverableType" column="deliverable_type"/>
        <result property="fileUrl" column="file_url"/>
        <result property="fileName" column="file_name"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectByTaskId" resultMap="deliverableVoMap">
        SELECT id, outsource_task_id, deliverable_type, file_url, file_name, remark,
               create_by, create_time, update_by, update_time
        FROM outsource_deliverable
        WHERE outsource_task_id = #{taskId} AND deleted = 0
        ORDER BY create_time DESC
    </select>

    <select id="countByTaskId" resultType="java.util.Map">
        SELECT deliverable_type AS deliverableType, COUNT(*) AS cnt
        FROM outsource_deliverable
        WHERE outsource_task_id = #{taskId} AND deleted = 0
        GROUP BY deliverable_type
    </select>

</mapper>
