<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vibe.agent.mapper.OutsourceWorkloadMapper">

    <resultMap id="workloadVoMap" type="com.vibe.agent.vo.OutsourceWorkloadVO">
        <id property="id" column="id"/>
        <result property="outsourceTaskId" column="outsource_task_id"/>
        <result property="manDays" column="man_days"/>
        <result property="siteCount" column="site_count"/>
        <result property="deviceCount" column="device_count"/>
        <result property="submittedBy" column="submitted_by"/>
        <result property="confirmedBy" column="confirmed_by"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectByTaskId" resultMap="workloadVoMap">
        SELECT id, outsource_task_id, man_days, site_count, device_count,
               submitted_by, confirmed_by, status, remark,
               create_by, create_time, update_by, update_time
        FROM outsource_workload
        WHERE outsource_task_id = #{taskId} AND deleted = 0
        ORDER BY create_time DESC
    </select>

</mapper>
