<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- Spring Boot 父 POM -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.5</version>
        <relativePath/>
    </parent>

    <groupId>com.vibe</groupId>
    <artifactId>vibe-server</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>vibe-server</name>
    <description>网络设备原厂实施项目管理系统 - 后端 Maven 多模块工程</description>

    <!-- 子模块列表 -->
    <modules>
        <module>module-common</module>
        <module>module-auth</module>
        <module>module-project</module>
        <module>module-device</module>
        <module>module-resource</module>
        <module>module-delivery</module>
        <module>module-agent</module>
        <module>module-acceptance</module>
        <module>module-finance</module>
        <module>module-collaboration</module>
        <module>module-integration</module>
        <module>module-report</module>
        <module>module-system</module>
        <module>module-lowcode</module>
        <module>vibe-server-bootstrap</module>
    </modules>

    <!-- 统一版本管理 -->
    <properties>
        <java.version>17</java.version>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- 框架版本（spring-boot 由 parent 管理，此处声明业务依赖版本）-->
        <mybatis-plus.version>3.5.7</mybatis-plus.version>
        <knife4j.version>4.5.0</knife4j.version>
        <easyexcel.version>3.3.4</easyexcel.version>
        <hutool.version>5.8.27</hutool.version>
        <mapstruct.version>1.5.5.Final</mapstruct.version>
        <lombok.version>1.18.38</lombok.version>
        <lombok-mapstruct-binding.version>0.2.0</lombok-mapstruct-binding.version>
        <jjwt.version>0.12.5</jjwt.version>
        <minio.version>8.5.10</minio.version>
        <thumbnailator.version>0.4.20</thumbnailator.version>
        <redisson.version>3.31.0</redisson.version>
        <mysql.version>8.0.33</mysql.version>
        <!-- 工作流引擎：Flowable 7（兼容 Spring Boot 3.2 / Jakarta EE） -->
        <flowable.version>7.0.1</flowable.version>
        <!-- Elasticsearch Java API Client 8.x -->
        <elasticsearch-java.version>8.11.0</elasticsearch-java.version>
        <!-- XXL-JOB 分布式任务调度 -->
        <xxl-job.version>2.4.1</xxl-job.version>
        <!-- Flyway 8.5.13 数据库迁移（最后支持 MySQL 5.7 的版本；9.0+ 要求 MySQL 8.0+） -->
        <flyway.version>8.5.13</flyway.version>
        <!-- Spring Cloud 2023.0.x（Leyton）兼容 Spring Boot 3.2.x，提供 OpenFeign 声明式 HTTP 客户端 -->
        <spring-cloud.version>2023.0.3</spring-cloud.version>
        <!-- Resilience4j 2.x（Spring Boot 3 starter）熔断/重试/限流/降级 -->
        <resilience4j.version>2.2.0</resilience4j.version>
        <!-- Micrometer Tracing 1.2.x（Spring Boot 3.2.x 对应版本，链路追踪桥接到 Brave/Zipkin） -->
        <micrometer-tracing.version>1.2.5</micrometer-tracing.version>
        <!-- Zipkin Reporter 2.17.x（Span 数据上报到 Zipkin Server） -->
        <zipkin-reporter.version>2.17.2</zipkin-reporter.version>
    </properties>

    <dependencyManagement>
            <dependencies>
            <!-- Byte Buddy 版本覆盖：Mockito 内联 mock 需要 Byte Buddy 支持当前 JDK。
                 Spring Boot 3.2.5 管理的 1.14.x 仅支持到 Java 22，显式升级到 1.15.10 以支持 Java 25。 -->
            <dependency>
                <groupId>net.bytebuddy</groupId>
                <artifactId>byte-buddy</artifactId>
                <version>1.15.10</version>
            </dependency>
            <dependency>
                <groupId>net.bytebuddy</groupId>
                <artifactId>byte-buddy-agent</artifactId>
                <version>1.15.10</version>
            </dependency>
            <!-- 模块间依赖 -->
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-common</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-auth</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-project</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-device</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-resource</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-delivery</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-agent</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-acceptance</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-finance</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-collaboration</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-integration</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-report</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-system</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.vibe</groupId>
                <artifactId>module-lowcode</artifactId>
                <version>${project.version}</version>
            </dependency>

            <!-- MyBatis-Plus（3.5.7 的 starter 已传递依赖 jsqlparser 4.9，PaginationInnerInterceptor 可直接使用） -->
            <dependency>
                <groupId>com.baomidou</groupId>
                <artifactId>mybatis-plus-spring-boot3-starter</artifactId>
                <version>${mybatis-plus.version}</version>
            </dependency>

            <!-- Knife4j (OpenAPI 3) -->
            <dependency>
                <groupId>com.github.xiaoymin</groupId>
                <artifactId>knife4j-openapi3-jakarta-spring-boot-starter</artifactId>
                <version>${knife4j.version}</version>
            </dependency>

            <!-- EasyExcel -->
            <dependency>
                <groupId>com.alibaba</groupId>
                <artifactId>easyexcel</artifactId>
                <version>${easyexcel.version}</version>
            </dependency>

            <!-- Hutool -->
            <dependency>
                <groupId>cn.hutool</groupId>
                <artifactId>hutool-all</artifactId>
                <version>${hutool.version}</version>
            </dependency>

            <!-- MapStruct -->
            <dependency>
                <groupId>org.mapstruct</groupId>
                <artifactId>mapstruct</artifactId>
                <version>${mapstruct.version}</version>
            </dependency>
            <dependency>
                <groupId>org.mapstruct</groupId>
                <artifactId>mapstruct-processor</artifactId>
                <version>${mapstruct.version}</version>
            </dependency>

            <!-- JJWT -->
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-api</artifactId>
                <version>${jjwt.version}</version>
            </dependency>
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-impl</artifactId>
                <version>${jjwt.version}</version>
            </dependency>
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-jackson</artifactId>
                <version>${jjwt.version}</version>
            </dependency>

            <!-- MinIO -->
            <dependency>
                <groupId>io.minio</groupId>
                <artifactId>minio</artifactId>
                <version>${minio.version}</version>
            </dependency>

            <!-- Thumbnailator 图片处理 -->
            <dependency>
                <groupId>net.coobird</groupId>
                <artifactId>thumbnailator</artifactId>
                <version>${thumbnailator.version}</version>
            </dependency>

            <!-- Redisson -->
            <dependency>
                <groupId>org.redisson</groupId>
                <artifactId>redisson-spring-boot-starter</artifactId>
                <version>${redisson.version}</version>
            </dependency>

            <!-- MySQL 驱动 -->
            <dependency>
                <groupId>com.mysql</groupId>
                <artifactId>mysql-connector-j</artifactId>
                <version>${mysql.version}</version>
            </dependency>

            <!-- Flowable 7 工作流引擎（BPMN 2.0 流程引擎，支撑验收/割接/外包/项目变更等审批流） -->
            <dependency>
                <groupId>org.flowable</groupId>
                <artifactId>flowable-spring-boot-starter-process</artifactId>
                <version>${flowable.version}</version>
            </dependency>

            <!-- Spring Boot Data Elasticsearch（版本由 spring-boot-dependencies BOM 管理，此处无需重复声明） -->

            <!-- Elasticsearch Java API Client 8.x（替代 deprecated 的 RestHighLevelClient） -->
            <dependency>
                <groupId>co.elastic.clients</groupId>
                <artifactId>elasticsearch-java</artifactId>
                <version>${elasticsearch-java.version}</version>
            </dependency>

            <!-- XXL-JOB 分布式任务调度（库存预警/备件补货/工单超时/验收逾期/进度同步/数据清理/财务对账） -->
            <dependency>
                <groupId>com.xuxueli</groupId>
                <artifactId>xxl-job-core</artifactId>
                <version>${xxl-job.version}</version>
            </dependency>

            <!-- Flyway 数据库迁移（替代 spring.sql.init，管理 V2+ 增量 DDL；V1 baseline 占位标记现有 schema.sql） -->
            <dependency>
                <groupId>org.flywaydb</groupId>
                <artifactId>flyway-core</artifactId>
                <version>${flyway.version}</version>
            </dependency>
            <!-- Flyway MySQL 支持模块（Flyway 8.x 起 MySQL 支持独立为 flyway-mysql artifact，支持 DELIMITER 语法解析） -->
            <dependency>
                <groupId>org.flywaydb</groupId>
                <artifactId>flyway-mysql</artifactId>
                <version>${flyway.version}</version>
            </dependency>

            <!-- Spring Cloud 2023.0.x BOM（兼容 Spring Boot 3.2.x，统一管理 Spring Cloud 全家桶版本） -->
            <!-- spring-cloud-starter-openfeign 版本由该 BOM 管理，子模块直接 <dependencies> 引入即可 -->
            <dependency>
                <groupId>org.springframework.cloud</groupId>
                <artifactId>spring-cloud-dependencies</artifactId>
                <version>${spring-cloud.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Resilience4j Spring Boot 3 Starter（2.x 版本，提供 @CircuitBreaker/@Retry/@RateLimiter 注解 AOP 切面与自动配置） -->
            <dependency>
                <groupId>io.github.resilience4j</groupId>
                <artifactId>resilience4j-spring-boot3</artifactId>
                <version>${resilience4j.version}</version>
            </dependency>
            <!-- Resilience4j 注解包（@CircuitBreaker/@Retry 注解定义，与 spring-boot3 starter 配合使用） -->
            <dependency>
                <groupId>io.github.resilience4j</groupId>
                <artifactId>resilience4j-reactor</artifactId>
                <version>${resilience4j.version}</version>
            </dependency>

            <!-- Micrometer Tracing + Zipkin（适配 Spring Boot 3.2，替代 Spring Cloud Sleuth） -->
            <!-- 显式声明版本，避免 dependencyManagement 直接条目覆盖 BOM 传递管理导致 "version missing" -->
            <!-- micrometer-tracing-bridge-brave：将 Micrometer Observation 桥接到 Brave，自动注入 traceId/spanId 到 MDC -->
            <dependency>
                <groupId>io.micrometer</groupId>
                <artifactId>micrometer-tracing-bridge-brave</artifactId>
                <version>${micrometer-tracing.version}</version>
            </dependency>
            <!-- zipkin-reporter-brave：将 Span 数据以 Zipkin v2 格式上报到 Zipkin Server / OTLP 兼容后端 -->
            <dependency>
                <groupId>io.zipkin.reporter2</groupId>
                <artifactId>zipkin-reporter-brave</artifactId>
                <version>${zipkin-reporter.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!-- 全局依赖（所有子模块继承）-->
    <dependencies>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <configuration>
                        <source>${java.version}</source>
                        <target>${java.version}</target>
                        <encoding>${project.build.sourceEncoding}</encoding>
                        <annotationProcessorPaths>
                            <path>
                                <groupId>org.projectlombok</groupId>
                                <artifactId>lombok</artifactId>
                                <version>${lombok.version}</version>
                            </path>
                            <path>
                                <groupId>org.mapstruct</groupId>
                                <artifactId>mapstruct-processor</artifactId>
                                <version>${mapstruct.version}</version>
                            </path>
                            <path>
                                <groupId>org.projectlombok</groupId>
                                <artifactId>lombok-mapstruct-binding</artifactId>
                                <version>${lombok-mapstruct-binding.version}</version>
                            </path>
                        </annotationProcessorPaths>
                    </configuration>
                </plugin>
                <!-- Surefire 测试插件：启用 Byte Buddy 实验模式以支持 Java 25。
                     Mockito 内联 mock 依赖 Byte Buddy 进行字节码增强，
                     当前 Byte Buddy 官方仅支持到 Java 22，需启用实验模式。 -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <configuration>
                        <argLine>-Dnet.bytebuddy.experimental=true --enable-native-access=ALL-UNNAMED</argLine>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

</project>
