# ============================================================================
# vibe-web .dockerignore
# 减少构建上下文体积，加速镜像构建
# ============================================================================

# 依赖目录（容器内重新安装）
node_modules/

# 构建产物（容器内重新构建）
dist/
dist-ssr/
*.local

# IDE 配置
.idea/
.vscode/
*.iml

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Git
.git/
.gitignore
.gitattributes

# 文档
*.md

# Docker 自身文件
Dockerfile
.dockerignore
docker-compose*.yml

# 测试与覆盖率
coverage/
.nyc_output/

# 临时文件
*.tmp
*.bak
*.swp
*~

# 操作系统文件
.DS_Store
Thumbs.db

# 环境变量（构建产物由 .env.production 注入，本地环境文件无需进入镜像）
.env.local
.env.*.local
